# Base URL used for server-side and client-side fetch calls
# Local: http://localhost:3000
# Production: https://your-vercel-domain.vercel.app
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Vercel Postgres — injected automatically when the DB is linked in the Vercel dashboard
# For local dev, copy the values from the Vercel project's Storage tab
POSTGRES_URL=

# NextAuth
NEXTAUTH_SECRET=                  # generate with: openssl rand -base64 32

# Admin credentials provider
ADMIN_USER=
ADMIN_PASSWORD=

# Google OAuth provider
# Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
